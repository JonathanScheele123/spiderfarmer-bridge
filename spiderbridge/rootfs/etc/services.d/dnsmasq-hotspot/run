#!/bin/sh
HOTSPOT_ENABLED=$(jq -r '.hotspot_enabled' /data/options.json)
if [ "${HOTSPOT_ENABLED}" != "true" ]; then
    # DNS-Interception-Modus: dnsmasq dient als Netzwerk-DNS (Rewrite + Forwarding),
    # sofern 01-hotspot-setup eine Config geschrieben hat. Warten bis sie da ist.
    i=0
    while [ ! -f /tmp/spiderbridge/dnsmasq.conf ] && [ "${i}" -lt 10 ]; do sleep 1; i=$((i+1)); done
    if [ -f /tmp/spiderbridge/dnsmasq.conf ]; then
        echo "[INFO] Starting dnsmasq (DNS interception mode)"
        exec dnsmasq --no-daemon -C /tmp/spiderbridge/dnsmasq.conf
    fi
    echo "[INFO] dnsmasq: disabled (no config)"
    exec sleep infinity
fi
echo "[INFO] Starting dnsmasq"
exec dnsmasq --no-daemon -C /tmp/spiderbridge/dnsmasq.conf
