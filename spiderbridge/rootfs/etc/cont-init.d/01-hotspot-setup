#!/bin/sh
set -e

HOTSPOT_ENABLED=$(jq -r '.hotspot_enabled' /data/options.json)

if [ "${HOTSPOT_ENABLED}" != "true" ]; then
    # DNS-Interception-Modus (kein Hotspot, kein Pi-Ethernet noetig): dnsmasq laeuft als
    # Netzwerk-DNS (nur Rewrite + Forwarding, KEIN DHCP). Der Router zeigt seinen
    # lokalen DNS auf diesen Host; der GGS loest dann sf.mqtt.spider-farmer.com auf diese
    # Host-IP auf, trifft 8883 -> per iptables auf den MITM-Proxy (18883) umgebogen
    # (Mosquitto/anderes belegt 8883 sonst).
    IFACE="wlan0"
    HOST_IP=$(ip -4 addr show "${IFACE}" 2>/dev/null | grep -oE 'inet [0-9.]+' | awk '{print $2}' | head -1)
    [ -z "${HOST_IP}" ] && HOST_IP=$(ip -4 route get 1.1.1.1 2>/dev/null | grep -oE 'src [0-9.]+' | awk '{print $2}' | head -1)
    GW=$(ip route 2>/dev/null | awk '/default/{print $3; exit}')
    echo "[INFO] Hotspot disabled — DNS interception mode (host ${HOST_IP}, iface ${IFACE})"

    iptables -t nat -F PREROUTING 2>/dev/null || true
    iptables -t nat -A PREROUTING -p tcp --dport 8883 -j REDIRECT --to-ports 18883 2>/dev/null || true
    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true

    mkdir -p /tmp/spiderbridge
    chmod 700 /tmp/spiderbridge
    {
        echo "interface=${IFACE}"
        echo "bind-interfaces"
        echo "no-dhcp-interface=${IFACE}"
        echo "no-resolv"
        echo "address=/sf.mqtt.spider-farmer.com/${HOST_IP}"
        # Lokale Router-Namen weiter beim Router aufloesen (kein Loop, da der Router
        # nur diese Domain zurueckschickt); alles andere ueber oeffentliche Resolver.
        [ -n "${GW}" ] && echo "server=/fritz.box/${GW}"
        echo "server=1.1.1.1"
        echo "server=8.8.8.8"
    } > /tmp/spiderbridge/dnsmasq.conf
    chmod 600 /tmp/spiderbridge/dnsmasq.conf
    echo "[INFO] DNS rewrite ready: sf.mqtt.spider-farmer.com -> ${HOST_IP}"
    exit 0
fi

SSID=$(jq -r '.ssid' /data/options.json)
PASSWORD=$(jq -r '.password' /data/options.json)
CHANNEL=$(jq -r '.channel' /data/options.json)
IP=$(jq -r '.hotspot_ip' /data/options.json)
IFACE="wlan0"

# Hosts without a wifi adapter (amd64 NUC / VM / bare-metal x86) have no
# wlan0. Refuse to run hotspot setup there instead of crashing s6 on the
# first `ip link set wlan0 up`. The proxy itself doesn't need the AP —
# users on such hosts should disable the hotspot option AND steer the
# GGS controller via DNS override on their router.
if ! ip link show "${IFACE}" >/dev/null 2>&1; then
    echo "[WARN] No ${IFACE} interface found — skipping hotspot setup."
    echo "[WARN] Set hotspot_enabled: false in addon options on hosts without WiFi."
    echo "[WARN] Steer the GGS controller via DNS override (sf.mqtt.spider-farmer.com → HA host IP)."
    exit 0
fi

echo "[INFO] Setting up hotspot: ${SSID} on ${IFACE} (${IP})"

mkdir -p /etc/NetworkManager/conf.d
printf '[keyfile]\nunmanaged-devices=interface-name:%s\n' "${IFACE}" > /etc/NetworkManager/conf.d/spiderbridge-unmanaged.conf
nmcli general reload 2>/dev/null || true

ip link set "${IFACE}" down 2>/dev/null || true
ip addr flush dev "${IFACE}" 2>/dev/null || true
ip link set "${IFACE}" up
ip addr add "${IP}/24" dev "${IFACE}"

# Stability: disable Wi-Fi powersave (was causing daily AP dropouts on standalone Pi)
iw dev "${IFACE}" set power_save off 2>/dev/null || true

# ieee80211w=0 disables Protected Management Frames — the GGS Controller does
# not negotiate PMF and silently drops association when it is required.
mkdir -p /tmp/spiderbridge
chmod 700 /tmp/spiderbridge
printf 'interface=%s\nssid=%s\nhw_mode=g\nchannel=%s\nwpa=2\nwpa_passphrase=%s\nwpa_key_mgmt=WPA-PSK\nwpa_pairwise=CCMP\nrsn_pairwise=CCMP\nieee80211w=0\n' \
    "${IFACE}" "${SSID}" "${CHANNEL}" "${PASSWORD}" > /tmp/spiderbridge/hostapd.conf
# hostapd.conf carries the WPA passphrase in plaintext — keep it
# readable only by root, not world-readable as /tmp defaults.
chmod 600 /tmp/spiderbridge/hostapd.conf

SUBNET=$(echo "${IP}" | cut -d. -f1-3)
printf 'interface=%s\nbind-interfaces\ndhcp-range=%s.10,%s.50,255.255.255.0,24h\naddress=/sf.mqtt.spider-farmer.com/%s\nno-resolv\nserver=8.8.8.8\n' \
    "${IFACE}" "${SUBNET}" "${SUBNET}" "${IP}" > /tmp/spiderbridge/dnsmasq.conf
chmod 600 /tmp/spiderbridge/dnsmasq.conf

iptables -t nat -F PREROUTING 2>/dev/null || true
# Redirect controller traffic from the standard MQTT-TLS port (8883)
# to our internal proxy port (18883). Avoids a port conflict with
# Mosquitto's own 8883 TLS listener — both can bind 0.0.0.0 because
# host_network: true. Only traffic arriving via wlan0 (i.e. from the
# GGS controller) is rewritten; LAN clients reaching the host's 8883
# still hit Mosquitto.
iptables -t nat -A PREROUTING -i "${IFACE}" -p tcp --dport 8883 -j REDIRECT --to-ports 18883
# ip_forward: try sysctl first; the shell-level redirect to /proc fails
# noisily on read-only /proc (no SYS_ADMIN), so wrap the fallback in a
# subshell whose stderr is silenced. NAT REDIRECT in PREROUTING actually
# works without ip_forward, so a failure here is non-fatal anyway.
sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 \
    || (echo 1 > /proc/sys/net/ipv4/ip_forward) 2>/dev/null \
    || true
echo "[INFO] Hotspot setup complete"
